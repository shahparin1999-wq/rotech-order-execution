{
  "name": "rotech-order-execution-prototype",
  "version": "0.1.0",
  "private": true,
  "description": "Mock-data vertical-slice prototype for the Rotech Order Execution and Digital Traveler. No production integrations.",
  "scripts": {
    "dev": "next dev --port 3100",
    "build": "next build",
    "start": "next start --port 3100",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests e2e",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "screenshots": "playwright test e2e/screenshots.spec.ts",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "next": "15.1.6",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "1.50.1",
    "@types/node": "22.10.10",
    "@types/react": "19.0.8",
    "@types/react-dom": "19.0.3",
    "eslint": "9.18.0",
    "typescript": "5.7.3",
    "typescript-eslint": "8.21.0",
    "vitest": "2.1.9"
  }
}
